# ==========================================================================
#  KHDN Viettel HCM - Landing page | Bien moi truong
#  Copy file nay thanh .env va dien gia tri thuc te.
# ==========================================================================

# --- Co ban ---
# URL cong khai cua site (dung cho SEO, sitemap, link trong email)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Chuoi bi mat cua Payload (BAT BUOC). Tao bang: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_dung_chuoi_ngau_nhien_64_ky_tu

# --- Database ---
# DB_ADAPTER = sqlite (dev) | postgres (production / Viettel Cloud)
DB_ADAPTER=sqlite
# sqlite:  file:./payload.db
# postgres: postgres://user:pass@host:5432/dbname
DATABASE_URI=file:./payload.db

# --- Email (SMTP noi bo Viettel) - de trong khi dev (se log ra console) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@khdn-viettel-hcm.vn
SMTP_FROM_NAME=KHDN Viettel HCM
# Email nhan thong bao lead moi (cach nhau dau phay)
SALES_NOTIFY_EMAILS=

# --- Thong bao lead realtime ---
# Telegram bot: tao bot voi @BotFather, lay token; chat_id la nhom/ca nhan nhan tin
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Zalo OA (tuy chon): access token cua Official Account
ZALO_OA_ACCESS_TOKEN=
ZALO_NOTIFY_USER_ID=

# --- Chong spam form dat lich (Cloudflare Turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADpi5b50ZZ838-0u
TURNSTILE_SECRET_KEY=0x4AAAAAADpi5WAyOgGV9SGAblTWPMf1jtk

# --- Luu media tren Object Storage Viettel IDC (S3-compatible) - tuy chon ---
# CO S3_BUCKET => day media len Object Storage. De trong => luu o thu muc ./media (mac dinh dev).
S3_BUCKET=
# Endpoint Object Storage Viettel IDC, vd: https://s3.cloudstorage.com.vn (lay tu portal IDC)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Viettel IDC / Ceph thuong can path-style = true (mac dinh true; chi dat false neu provider dung virtual-hosted)
S3_FORCE_PATH_STYLE=true
